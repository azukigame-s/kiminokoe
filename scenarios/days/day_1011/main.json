	{
		"type": "jump",
		"index": 900
	},
	{
		"type": "index",
		"index": 300
	},
	{
		"type": "dialogue",
		"text": "　イロが僕の方へ近づいてきた。"
	},
	{
		"type": "dialogue",
		"text": "「お兄ちゃん、大丈夫？」"
	},
	{
		"type": "dialogue",
		"text": "　イロの心配そうな顔が、僕を見つめている。"
	},
	{
		"type": "dialogue",
		"text": "　僕は頷いた。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "「あのね――私、スグちゃんのこと、ほとんど知らないんだ」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "　イロの声が小さくなる。"
	},
	{
		"type": "dialogue",
		"text": "「写真でしか見たことないし、お母さんもあまり話してくれなかったから」",
		"go_next": true
