	{
		"type": "dialogue",
		"text": "その顔は霞んでいて、ぼんやりとしていた。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "少年のことは気になるが、そろそろお墓参りに行かないといけない。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "イロと二人で歩き始めた。"
	},
