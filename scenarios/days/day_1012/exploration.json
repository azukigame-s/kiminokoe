	{
		"type": "dialogue",
		"text": "気が付くと、波打ち際に白い服の少年が立っていた。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "真っ白な服、少しカールした黒髪。"
	},
	{
		"type": "dialogue",
		"text": "少年は海を見つめている。"
	},
	{
		"type": "dialogue",
