		"new_page": true
	},
	{
		"type": "background",
		"path": "res://assets/backgrounds/forest.jpg"
	},
	{
		"type": "dialogue",
		"text": "もう、クワガタのことなんて、どうでもよかった。"
	},
	{
		"type": "dialogue",
		"text": "ただ――ただ、家に帰りたかった。"
	},
	{
		"type": "dialogue",
		"text": "木々を抜け。"
	},
	{
		"type": "dialogue",
		"text": "猟師さんの家が見えた。"
	},
	{
		"type": "background",
