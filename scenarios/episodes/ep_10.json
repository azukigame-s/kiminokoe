	},
	{
		"type": "dialogue",
		"text": "お寺の門。"
	},
	{
		"type": "dialogue",
		"text": "そして――。",
		"go_next": true
	},
	{
		"type": "background",
		"path": "res://assets/backgrounds/house_front.jpg"
	},
	{
		"type": "dialogue",
		"text": "「おばあちゃーん！」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "見慣れた家が目に入る。"
	},
	{
		"type": "dialogue",
		"text": "スグが泣きながら叫ぶ。"
	},
	{
		"type": "dialogue",
		"text": "僕も――我慢できずに、泣いていた。"
	},
	{
		"type": "dialogue",
		"text": "「なんだいな？　二人とも泣いてぇ」"
	},
	{
		"type": "dialogue",
		"text": "祖母が驚いて飛び出してくる。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "「道に、迷って……」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "それだけ言うのが精一杯だった。"
	},
	{
		"type": "dialogue",
		"text": "「そっか、そっか――」"
	},
	{
		"type": "dialogue",
		"text": "祖母は僕たちを抱きしめてくれた。"
	},
	{
		"type": "dialogue",
