[
	{
		"type": "dialogue",
		"text": "「クワガタいるかなぁ」"
	},
	{
		"type": "dialogue",
		"text": "…………聞き覚えのある声が聞こえてくる。",
		"go_next": true
	},
	{
		"type": "bgm",
		"name": "flashback"
	},
	{
		"type": "flashback_start",
		"effect": "grayscale",
		"gradual": true,
		"duration": 4.5
	},
	{
		"type": "dialogue",
		"text": "……。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "…………。"
	},
	{
		"type": "dialogue",
		"text": "………………。"
	},
	{
		"type": "background",
		"path": "res://assets/backgrounds/forest.jpg"
	},
	{
		"type": "dialogue",
		"text": "「あそこの犬……飛び出して来ないよね？」"
	},
	{
		"type": "dialogue",
		"text": "スグの不安そうな声を聞き、僕は遠目に猟師さんの家の方を見る。"
	},
	{
		"type": "dialogue",
		"text": "「多分……大丈夫だよ」"
	},
	{
		"type": "dialogue",
		"text": "僕もあの大きな犬が飛び出てきたら……と思うと落ち着かなかったが、これまで飛び出して来たことはないので、不安ながらそう応えた。"
	},
	{
		"type": "dialogue",
		"text": "二人で駆け足になりながら、山道に続く道を急いだ。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "ミンミンと騒がしさが増してきた。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "額には汗が流れてくる。"
	},
	{
		"type": "dialogue",
		"text": "今日はスグと二人でクワガタを捕まえに、お寺の先の山道に来ていた。"
	},
	{
		"type": "dialogue",
		"text": "「クワガタいるかなぁ」"
	},
	{
		"type": "dialogue",
		"text": "スグが期待に胸を膨らませている。"
	},
	{
		"type": "dialogue",
		"text": "先程までの不安はどこかに行ってくれたようで、一安心だ。"
	},
	{
		"type": "dialogue",
		"text": "「いるさ。この辺りはクワガタの宝庫なんだから」"
	},
	{
		"type": "dialogue",
		"text": "僕の不安も飛んでいったようで、自信満々にそう答えた。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "参道に入って程なく木々が生い茂ってきた。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "大きめの木を見つけては、幹を揺らす。"
	},
	{
		"type": "dialogue",
		"text": "ガサガサと葉が揺れる音。"
	},
	{
		"type": "dialogue",
		"text": "葉はひらひらと舞うも、クワガタは落ちてこなかった。"
	},
	{
		"type": "dialogue",
		"text": "「次、次！」"
	},
	{
		"type": "dialogue",
		"text": "スグは元気な歩幅で歩みを進める。"
	},
	{
		"type": "dialogue",
		"text": "僕たちは、どんどん奥へと進んでいった。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "何本目かの木を揺らしたとき――。",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "ふと、辺りが暗くなっていることに気づいた。"
	},
	{
		"type": "background",
		"path": "res://assets/backgrounds/copse.jpg"
	},
	{
		"type": "dialogue",
		"text": "夕暮れが近い。"
	},
	{
		"type": "dialogue",
		"text": "それに、木々が深くなっている。"
	},
	{
		"type": "dialogue",
		"text": "「お兄ちゃん……なんか暗くなってきたね」"
	},
	{
		"type": "dialogue",
		"text": "スグが不安そうに僕を見上げる。"
	},
	{
		"type": "dialogue",
		"text": "「大丈夫だよ。もう少し探そう」"
	},
	{
		"type": "dialogue",
		"text": "僕はそう言ったものの、少し不安になっていた。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "「流石に、そろそろ……落ちてくれよ――」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "僕は渾身の力で木を揺らす。"
	},
	{
		"type": "dialogue",
		"text": "バサバサという音とともに、何かが落ちた。"
	},
	{
		"type": "dialogue",
		"text": "「ひゃあっ！」"
	},
	{
		"type": "dialogue",
		"text": "スグの小さな悲鳴を聞いたと思ったら、奥へ走り出してしまった。"
	},
	{
		"type": "dialogue",
		"text": "「スグ！　待って！」"
	},
	{
		"type": "dialogue",
		"text": "僕は慌てて追いかけた。",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "「はあ……はあ……」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "すぐに追いついたものの、あたりの暗さは更に深まっている。"
	},
	{
		"type": "dialogue",
		"text": "「ごめん……怖くて……」"
	},
	{
		"type": "dialogue",
		"text": "肩で息をしているスグは、今にも泣きそうな様子だ。"
	},
	{
		"type": "dialogue",
		"text": "「大丈夫だよ」"
	},
	{
		"type": "dialogue",
		"text": "僕はスグの手を握った。"
	},
	{
		"type": "dialogue",
		"text": "「さ、帰ろう」",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "「あれ？」",
		"new_page": true
	},
	{
		"type": "dialogue",
		"text": "――違う。"
	},
	{
		"type": "dialogue",
		"text": "右をみても、左を見ても、前を見ても……そこには木々が広がっているだけだった。"
	},
	{
		"type": "dialogue",
		"text": "どこから来たのか――。"
	},
	{
		"type": "dialogue",
		"text": "分からない。"
	},
	{
		"type": "dialogue",
		"text": "「お兄ちゃん……？」"
	},
	{
		"type": "dialogue",
		"text": "スグが不安そうに僕を見る。"
	},
	{
		"type": "dialogue",
		"text": "――まずい。"
	},
	{
		"type": "dialogue",
		"text": "道が、分からない。"
	},
	{
		"type": "dialogue",
		"text": "来たはずの道が、どこにもない。",
		"go_next": true
	},
