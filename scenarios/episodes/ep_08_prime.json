	},
	{
		"type": "dialogue",
		"text": "スグの目が、少し大きくなった。"
	},
	{
		"type": "dialogue",
		"text": "「いいの……？」"
	},
	{
		"type": "dialogue",
		"text": "「うん。明日、ちゃんとプレゼントとして」",
		"go_next": true
	},
	{
		"type": "dialogue",
		"text": "スグは、少し考えてから――。",
		"new_page": true
	},
	{
