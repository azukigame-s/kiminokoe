	},
	{
		"type": "dialogue",
		"text": "「いいよ、もう」"
	},
	{
		"type": "dialogue",
		"text": "僕は首を横に振った。"
	},
	{
		"type": "dialogue",
		"text": "「え……？」"
	},
	{
